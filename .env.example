# =============================================
# frontend/.env.example
# 역할: 프론트엔드 환경변수 템플릿
# 사용법: cp .env.example .env  →  값 채우기
# 주의: VITE_ 접두사가 있어야 브라우저에서 접근 가능
# =============================================

# 백엔드 API 기본 URL
VITE_API_BASE_URL=http://localhost:8000

# WebSocket URL
VITE_WS_URL=ws://localhost:8000/api/v1/ws

# 카메라 스트림 URL (각 모드별)
VITE_STREAM_RGB_URL=/api/v1/stream/rgb
VITE_STREAM_THERMAL_URL=/api/v1/stream/thermal
VITE_STREAM_BLEND_URL=/api/v1/stream/blend

# 국세청 사업자 상태조회 API 키 (공공데이터포털 → "사업자등록정보 진위확인 및 상태조회 서비스")
# - 발급받은 "일반 인증키 (Decoding)" 값을 그대로 붙여넣기
# - 주의: VITE_ 접두사 env는 프론트엔드 번들에 노출됨. 운영에서는 백엔드 프록시로 전환 권장.
VITE_ODCLOUD_SERVICE_KEY=여기에_발급받은_디코딩_키_입력

# ── OAuth (SNS 로그인) ─────────────────
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_KAKAO_JS_KEY=your-kakao-javascript-key
VITE_NAVER_CLIENT_ID=your-naver-client-id

# ── Sentry (운영 에러 모니터링) ─────────
# 운영 환경에서만 설정. 로컬 개발은 비워두면 자동 no-op (init 도 skip).
# Vercel: Project Settings → Environment Variables 에 VITE_ 접두사로 등록.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
# 트랜잭션/리플레이 샘플링 — 비용 가드. 디버그 세션만 일시 상향.
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAYS_SESSION_RATE=0.0
VITE_SENTRY_REPLAYS_ERROR_RATE=1.0

# 빌드 시 sourcemap 업로드용 (vite.config.js — 셋 다 있어야 활성).
# 코드에는 절대 commit 하지 말 것. Vercel build env 에만 등록.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
